# ─────────────────────────────────────────────
#  RevTrack — Environment Variables
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5433
DB_NAME=revtrack
DB_USER=postgres
DB_PASSWORD=revtrack123
DB_SSL=false
DATABASE_URL=postgresql://postgres:revtrack123@localhost:5432/revtrack

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── Twilio (WhatsApp) ──────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# WhatsApp-enabled Twilio number (format: whatsapp:+14155238886)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Email (SMTP via Gmail / SendGrid) ─────
# For Gmail: enable App Passwords in Google Account
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=alerts@yourdomain.com
SMTP_PASS=your_app_password
EMAIL_FROM_NAME=RevTrack Alerts
EMAIL_FROM=alerts@yourdomain.com

# ── Scheduler ─────────────────────────────
# How many days before due to send first warning
WARN_DAYS_BEFORE=7
# How many days before due to send urgent reminder
URGENT_DAYS_BEFORE=3

# ── SMS (Twilio — plain SMS to phone number) ───────────────────────────
# Get a Twilio phone number from console.twilio.com/phone-numbers
# This is DIFFERENT from the WhatsApp number
TWILIO_SMS_FROM=+1XXXXXXXXXX
# TWILIO_PHONE_FROM is same as TWILIO_SMS_FROM (alias)
TWILIO_PHONE_FROM=+1XXXXXXXXXX
